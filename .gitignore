# Ignorar archivos sensibles y temporales
.env
.peon_env
backups/
tmp/
*.log
*.zip
.agent/
.agents/
scratch/
code/skills/

# Ignorar archivos de sistema de SO
.DS_Store
Thumbs.db

# Permitir todo lo demás (Dashboard, Logic, Assets, README)
/*
!/assets/
!/lang/
!/code/
!/*.php
!/*.md
!/*.json
!/LICENSE
!/.gitignore
!/.htaccess
