RewriteEngine On
RewriteBase /peon/

# ═══════════════════════════════════════
# 🛡️ PROTOCOLO DE BLINDAJE (SECURITY LAYER)
# ═══════════════════════════════════════

# Bloquear acceso a archivos sensibles
<FilesMatch "^\.|\.(env|log|sql|json|bak|config|swp|txt|md)|htaccess|htpasswd$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Permitir específicamente utilidades de telemetría
<Files "installer_utility.php">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Allow from all
    </IfModule>
</Files>

# Bloquear acceso a carpetas sensibles
RewriteRule ^(\.git|\.antigravity|backups|tmp|db|scripts)/ - [F,L]

# ═══════════════════════════════════════
# 🚀 RUTAS INTELIGENTES (CLEAN URLS)
# ═══════════════════════════════════════

# Manejar dashboard (index.php)
RewriteRule ^dashboard$ index.php [L]

# Manejar hierarchy (organigrama.php)
RewriteRule ^hierarchy$ organigrama.php [L]

# Manejar assets y archivos reales
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . dashboard [L]
